{
  "name": "gametime-api-client",
  "version": "1.0.0",
  "description": "JavaScript client for Gametime API - live sports data, player analysis, and predictions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
